[
  {
    "label": "Run Rust Server",
    "command": "cargo run",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Build Rust Server",
    "command": "cargo build",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Watch Rust Server",
    "command": "cargo watch -x run",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Test Rust file",
    "command": "cargo test $ZED_FILE",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Test Rust",
    "command": "cargo test",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Clippy",
    "command": "cargo clippy",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
]
